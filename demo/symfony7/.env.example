# Demo environment template. Copy to .env (e.g. cp .env.example .env) and adjust.
# Do not commit .env or local .env* files.

# APP_ENV: Symfony environment used by the demo container.
APP_ENV=dev

# APP_SECRET: local development secret placeholder.
APP_SECRET=change_this_secret_key_to_a_random_value

# APP_DEBUG: enable detailed debug output for local development.
APP_DEBUG=1

# PORT: HTTP port exposed by docker-compose for this demo.
PORT=8047

# TRUSTED_PROXIES: proxies trusted by Symfony behind Docker/Caddy.
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR

# DEFAULT_URI: default router URI used by Symfony routing components.
DEFAULT_URI=http://localhost:8047
